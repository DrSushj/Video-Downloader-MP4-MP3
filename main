# Features:
# - CapCut-ähnliche Dark UI
# - Direkte Video-Dateilinks: MP4, WEBM, MKV, MOV, AVI, M4V
# - Webseiten-Downloads über yt-dlp
# - Qualität: Beste, 1080p, 720p, 480p, Audio MP3
# - Ausgabe: MP4, MKV, WEBM
# - Playlist optional
# - Direkter Datei-Download mit größeren Chunks
# - Bessere Timeouts
# - FFmpeg-Erkennung im PATH und im gleichen Ordner wie diese Datei
# - Download abbrechen
# - Fortschritt, Speed, ETA, Log
#
# Hinweis:
# Nur für Inhalte verwenden, an denen du Rechte hast.
# Kein DRM-, Paywall-, Login- oder Schutz-Bypass.
# ============================================================

APP_NAME = "ClipVault Downloader"
APP_VERSION = "1.0"

DIRECT_VIDEO_EXTENSIONS = (".mp4", ".webm", ".mkv", ".mov", ".avi", ".m4v")
DIRECT_AUDIO_EXTENSIONS = (".mp3", ".wav", ".m4a", ".aac", ".ogg", ".flac")

