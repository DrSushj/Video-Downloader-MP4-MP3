        "480p": {"English": "480p", "Deutsch": "480p", "Spanish": "480p", "Italian": "480p", "French": "480p"},
        "audio_mp3": {"English": "Audio MP3 only", "Deutsch": "Nur Audio MP3", "Spanish": "Solo audio MP3", "Italian": "Solo audio MP3", "French": "Audio MP3 uniquement"},
    },
    "output": {
        "mp4": {"English": "MP4", "Deutsch": "MP4", "Spanish": "MP4", "Italian": "MP4", "French": "MP4"},
        "mkv": {"English": "MKV", "Deutsch": "MKV", "Spanish": "MKV", "Italian": "MKV", "French": "MKV"},
        "webm": {"English": "WEBM", "Deutsch": "WEBM", "Spanish": "WEBM", "Italian": "WEBM", "French": "WEBM"},
