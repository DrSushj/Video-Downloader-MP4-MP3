LICENSE_API_URL = "https://clipvault-license-api.kollekive-774.workers.dev"
OFFLINE_CACHE_DAYS = 30
APP_CACHE_DIR = Path(os.getenv("LOCALAPPDATA", str(Path.home()))) / "ClipVaultDownloader"
LICENSE_CACHE_FILE = APP_CACHE_DIR / "license_cache.dat"

YTDLP_EXE_URL = "https://github.com/yt-dlp/yt-dlp/releases/latest/download/yt-dlp.exe"
FFMPEG_ZIP_URL = "https://www.gyan.dev/ffmpeg/builds/ffmpeg-release-essentials.zip"


def get_device_fingerprint() -> str:
    raw = "|".join([
        platform.node(),
        platform.system(),
        platform.release(),
        os.getenv("USERNAME", ""),
        str(Path.home()),
    ])
    return hashlib.sha256(raw.encode("utf-8", errors="ignore")).hexdigest()


def cache_secret() -> bytes:
    raw = "ClipVaultOfflineCache|" + get_device_fingerprint()
    return hashlib.sha256(raw.encode("utf-8")).digest()


def xor_bytes(data: bytes, key: bytes) -> bytes:
    return bytes(b ^ key[i % len(key)] for i, b in enumerate(data))


def save_offline_license(normalized_key: str):
    try:
        APP_CACHE_DIR.mkdir(parents=True, exist_ok=True)

        now = datetime.now(timezone.utc)
        expires_at = now + timedelta(days=OFFLINE_CACHE_DAYS)

        payload = {
            "key_hash": hashlib.sha256(normalized_key.encode("utf-8")).hexdigest(),
            "device": get_device_fingerprint(),
            "issued_at": now.isoformat(),
            "expires_at": expires_at.isoformat(),
            "version": APP_VERSION,
        }

        raw = json.dumps(payload, separators=(",", ":")).encode("utf-8")
        encrypted = xor_bytes(raw, cache_secret())
        encoded = base64.urlsafe_b64encode(encrypted).decode("ascii")
        LICENSE_CACHE_FILE.write_text(encoded, encoding="utf-8")
    except Exception:
        pass


def load_offline_license() -> tuple[bool, str]:
    try:
        if not LICENSE_CACHE_FILE.exists():
            return False, "No offline license cache found."

        encoded = LICENSE_CACHE_FILE.read_text(encoding="utf-8").strip()
        encrypted = base64.urlsafe_b64decode(encoded.encode("ascii"))
        raw = xor_bytes(encrypted, cache_secret())
        payload = json.loads(raw.decode("utf-8"))

        if payload.get("device") != get_device_fingerprint():
            return False, "Offline license belongs to another device."

        expires_at = datetime.fromisoformat(payload.get("expires_at"))
        now = datetime.now(timezone.utc)

        if now > expires_at:
            return False, "Offline license expired. Please login online again."

        remaining = expires_at - now
        days_left = max(0, remaining.days)
        return True, f"Offline license valid. {days_left} days left."
    except Exception:
        return False, "Offline license cache invalid."


def has_internet_connection() -> bool:
    """
    Checks if the Cloudflare license worker is reachable.
    Uses GET intentionally. The Worker returns POST only when reachable,
    which still means online.
    """
    try:
        response = requests.get(LICENSE_API_URL, timeout=5)
        return response.status_code in (200, 400, 405)
    except Exception:
        return False



def mega_b64_decode(data: str) -> bytes:
    data = str(data).replace("-", "+").replace("_", "/")
    data += "=" * ((4 - len(data) % 4) % 4)
    return base64.b64decode(data)


def mega_b64_to_a32(data: str):
    raw = mega_b64_decode(data)
    return list(struct.unpack(">%dI" % (len(raw) // 4), raw))


def is_mega_url(url: str) -> bool:
    lowered = url.lower()
    return "mega.nz/file/" in lowered or "mega.co.nz/#!" in lowered


def is_mega_folder_url(url: str) -> bool:
    lowered = url.lower()
    return "mega.nz/folder/" in lowered or "mega.nz/#f!" in lowered


def parse_mega_file_url(url: str):
    """
    Supports:
    https://mega.nz/file/<file_id>#<key>
    https://mega.co.nz/#!<file_id>!<key>
    """
    parsed = urlparse(url)

    if "mega.nz" in parsed.netloc.lower():
        parts = parsed.path.strip("/").split("/")
        if len(parts) >= 2 and parts[0].lower() == "file":
            file_id = parts[1]
            file_key = parsed.fragment.strip()
            if file_id and file_key:
                return file_id, file_key

    if "mega.co.nz" in parsed.netloc.lower():
        frag = parsed.fragment.strip()
        if frag.startswith("!"):
            parts = frag.split("!")
            if len(parts) >= 3:
                return parts[1], parts[2]

    return None, None


def mega_file_key_and_nonce(key_string: str):
    key_a32 = mega_b64_to_a32(key_string)

    if len(key_a32) < 8:
        raise ValueError("Ungültiger MEGA-Key.")

    file_key_a32 = [
        key_a32[0] ^ key_a32[4],
        key_a32[1] ^ key_a32[5],
        key_a32[2] ^ key_a32[6],
        key_a32[3] ^ key_a32[7],
    ]

    file_key = struct.pack(">4I", *file_key_a32)
    nonce = struct.pack(">2I", key_a32[4], key_a32[5])
    return file_key, nonce


def mega_decrypt_attributes(attr_string: str, file_key: bytes) -> dict:
    if not attr_string:
        return {}

    raw = mega_b64_decode(attr_string)
    cipher = AES.new(file_key, AES.MODE_CBC, iv=b"\x00" * 16)
    decrypted = cipher.decrypt(raw)
    decrypted = decrypted.rstrip(b"\x00")

    if not decrypted.startswith(b"MEGA"):
        return {}

    try:
        return json.loads(decrypted[4:].decode("utf-8", errors="replace"))
    except Exception:
        return {}


