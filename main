    def refresh_dependency_paths(self):
        global AES, HAS_CRYPTO

        try:
            from Crypto.Cipher import AES as _AES
            AES = _AES
            HAS_CRYPTO = True
        except Exception:
            HAS_CRYPTO = False

        self.ffmpeg_path = find_local_or_path_exe("ffmpeg.exe") or find_local_or_path_exe("ffmpeg")
        self.ffprobe_path = find_local_or_path_exe("ffprobe.exe") or find_local_or_path_exe("ffprobe")
        self.ytdlp_path = find_ytdlp_exe()

        if hasattr(self, "ffmpeg_label"):
            self.ffmpeg_label.configure(
                text=TR[self.lang]["ffmpeg_found"] if self.ffmpeg_path else TR[self.lang]["ffmpeg_missing"],
                text_color=GREEN if self.ffmpeg_path else "#ffaa33",
            )

        if hasattr(self, "ffprobe_label"):
            self.ffprobe_label.configure(
                text=TR[self.lang]["ffprobe_found"] if self.ffprobe_path else TR[self.lang]["ffprobe_missing"],
                text_color=GREEN if self.ffprobe_path else "#ffaa33",
            )

        if hasattr(self, "ytdlp_label"):
            self.ytdlp_label.configure(
                text=tr(self.lang, "ytdlp_found") if self.ytdlp_path else tr(self.lang, "ytdlp_missing"),
                text_color=GREEN if self.ytdlp_path else "#ffaa33",
            )

        if hasattr(self, "crypto_label"):
            self.crypto_label.configure(
                text=tr(self.lang, "mega_ready") if HAS_CRYPTO else tr(self.lang, "mega_crypto_missing"),
                text_color=GREEN if HAS_CRYPTO else "#ffaa33",
            )

