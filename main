    def confirm_install_required_files(self):
        if getattr(self, "requirements_install_running", False):
            self.show_toast(tr(self.lang, "wait_title"), tr(self.lang, "already_downloading"), kind="info")
            return

        self.show_center_confirm_dialog(
            tr(self.lang, "requirements"),
            tr(self.lang, "requirements_desc"),
            yes_callback=self.install_required_files,
            no_callback=lambda: self.show_toast(tr(self.lang, "cancelled"), tr(self.lang, "requirements_cancelled"), kind="info"),
        )

    def install_required_files(self):
        if getattr(self, "requirements_install_running", False):
            self.show_toast(tr(self.lang, "wait_title"), tr(self.lang, "already_downloading"), kind="info")
            return

        self.requirements_install_running = True
        self.btn_requirements.configure(state="disabled", text="⬇  " + tr(self.lang, "installing"))
        self.show_toast(
            tr(self.lang, "requirements"),
            tr(self.lang, "requirements_start"),
            kind="info",
            duration=3600,
        )
        self.log(tr(self.lang, "requirements_started_log"))

        threading.Thread(target=self.install_required_files_worker, daemon=True).start()

    def install_required_files_worker(self):
        try:
            installed = []
            skipped = []

            tool_dir = app_dir()

            ytdlp_target = tool_dir / "yt-dlp.exe"
            if not ytdlp_target.exists():
                self.q.put(("status", tr(self.lang, "download_ytdlp_status")))
                self.download_file(YTDLP_EXE_URL, ytdlp_target, "yt-dlp.exe")
                installed.append("yt-dlp.exe")
            else:
                skipped.append("yt-dlp.exe")

            ffmpeg_target = tool_dir / "ffmpeg.exe"
            ffprobe_target = tool_dir / "ffprobe.exe"

            if not ffmpeg_target.exists() or not ffprobe_target.exists():
                self.q.put(("status", tr(self.lang, "download_ffmpeg_status")))
                zip_path = tool_dir / "_ffmpeg_download.zip"
                self.download_file(FFMPEG_ZIP_URL, zip_path, "FFmpeg Paket")
                self.extract_ffmpeg_binaries(zip_path, tool_dir)

                try:
                    zip_path.unlink(missing_ok=True)
                except Exception:
                    pass

                if ffmpeg_target.exists():
                    installed.append("ffmpeg.exe")
                if ffprobe_target.exists():
                    installed.append("ffprobe.exe")
            else:
                skipped.extend(["ffmpeg.exe", "ffprobe.exe"])

            if not HAS_CRYPTO:
                self.q.put(("status", tr(self.lang, "install_crypto_status")))
                self.install_python_package("pycryptodome", "pycryptodome")
                installed.append("pycryptodome")
            else:
                skipped.append("pycryptodome")

            self.q.put(("refresh_deps", None))

            msg_parts = []
            if installed:
                msg_parts.append(tr(self.lang, "installed") + ": " + ", ".join(installed))
            if skipped:
                msg_parts.append(tr(self.lang, "already_present") + ": " + ", ".join(skipped))

            final_msg = "\n".join(msg_parts) if msg_parts else tr(self.lang, "all_present")
            self.q.put(("info", final_msg))
            self.q.put(("log", tr(self.lang, "requirements_finished") + " " + final_msg.replace("\n", " | ")))
            self.q.put(("status", tr(self.lang, "requirements_finished")))

        except Exception as e:
            self.q.put(("error", f"{tr(self.lang, 'requirements_error')} {e}"))
            self.q.put(("log", f"{tr(self.lang, 'requirements_error')} {e}"))
            self.q.put(("status", tr(self.lang, "requirements_error")))
        finally:
            self.q.put(("requirements_done", None))

    def install_python_package(self, package_name: str, label: str):
        cmd = [
            sys.executable,
            "-m",
            "pip",
            "install",
            "--upgrade",
            package_name,
        ]

        process = subprocess.Popen(
            cmd,
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            text=True,
            encoding="utf-8",
            errors="replace",
            creationflags=subprocess.CREATE_NO_WINDOW if os.name == "nt" else 0,
        )

        try:
            for line in process.stdout:
                line = line.strip()
                if line:
                    self.q.put(("status", f"{label}: {line[:120]}"))
                    if "error" in line.lower() or "failed" in line.lower():
                        self.q.put(("log", f"{label}: {line[:400]}"))

            return_code = process.wait()
            if return_code != 0:
                raise RuntimeError(f"{label} Installation fehlgeschlagen. Exit-Code: {return_code}")

        finally:
            try:
                if process.poll() is None:
                    process.terminate()
            except Exception:
                pass

    def download_file(self, url: str, target: Path, label: str):
        target.parent.mkdir(parents=True, exist_ok=True)
        temp_target = target.with_suffix(target.suffix + ".part")

        headers = {"User-Agent": "Mozilla/5.0"}
        with requests.get(url, stream=True, timeout=(30, 300), headers=headers, allow_redirects=True) as r:
            r.raise_for_status()
            total = int(r.headers.get("content-length", 0) or 0)
            downloaded = 0
            start_time = time.time()

            with open(temp_target, "wb") as f:
                for chunk in r.iter_content(chunk_size=1024 * 1024 * 4):
                    if not chunk:
                        continue

                    f.write(chunk)
                    downloaded += len(chunk)

                    elapsed = max(time.time() - start_time, 0.1)
                    speed = downloaded / elapsed / 1024 / 1024
                    percent = downloaded / total if total else 0

                    if total:
                        self.q.put(("status", f"{label}: {percent * 100:.1f}% | {speed:.2f} MB/s"))
                    else:
                        self.q.put(("status", f"{label}: {downloaded / 1024 / 1024:.2f} MB | {speed:.2f} MB/s"))

            if target.exists():
                target.unlink()

            temp_target.replace(target)

    def extract_ffmpeg_binaries(self, zip_path: Path, tool_dir: Path):
        found_ffmpeg = False
        found_ffprobe = False

        with zipfile.ZipFile(zip_path, "r") as z:
            names = z.namelist()

            ffmpeg_name = next((n for n in names if n.lower().endswith("/bin/ffmpeg.exe")), None)
            ffprobe_name = next((n for n in names if n.lower().endswith("/bin/ffprobe.exe")), None)

            if not ffmpeg_name or not ffprobe_name:
                # fallback if zip structure changes
                ffmpeg_name = next((n for n in names if n.lower().endswith("ffmpeg.exe")), ffmpeg_name)
                ffprobe_name = next((n for n in names if n.lower().endswith("ffprobe.exe")), ffprobe_name)

            if ffmpeg_name:
                with z.open(ffmpeg_name) as src, open(tool_dir / "ffmpeg.exe", "wb") as dst:
                    shutil.copyfileobj(src, dst, length=1024 * 1024 * 8)
                found_ffmpeg = True

            if ffprobe_name:
                with z.open(ffprobe_name) as src, open(tool_dir / "ffprobe.exe", "wb") as dst:
                    shutil.copyfileobj(src, dst, length=1024 * 1024 * 8)
                found_ffprobe = True

        if not found_ffmpeg or not found_ffprobe:
            raise RuntimeError("ffmpeg.exe oder ffprobe.exe wurde im ZIP nicht gefunden.")

    # ========================================================
    # Basic UI actions
    # ========================================================
    def log(self, text: str):
        self.log_box.insert("end", f"[{time.strftime('%H:%M:%S')}] {text}\n")
        self.log_box.see("end")

    def set_status(self, text: str):
        self.status_label.configure(text=text)

    def choose_folder(self):
        folder = filedialog.askdirectory(initialdir=self.download_dir)
        if folder:
            self.download_dir = folder
            self.folder_entry.delete(0, "end")
            self.folder_entry.insert(0, folder)

    def open_folder(self):
        folder = self.folder_entry.get().strip() or self.download_dir
        Path(folder).mkdir(parents=True, exist_ok=True)
        try:
            webbrowser.open(Path(folder).resolve().as_uri())
        except Exception:
            os.startfile(folder)

    def set_downloading_ui(self, downloading: bool):
        self.is_downloading = downloading
        if downloading:
            self.cancel_requested = False
            self.start_button.configure(text=tr(self.lang, "running"), state="disabled")
            self.cancel_button.configure(state="normal")
            self.check_button.configure(state="disabled")
            self.progress.set(0)
        else:
            self.cancel_requested = False
            self.start_button.configure(text=TR[self.lang]["start_download"], state="normal")
            self.cancel_button.configure(state="disabled")
            self.check_button.configure(state="normal")

    def cancel_download(self):
        if self.is_downloading:
            self.cancel_requested = True
            self.set_status(tr(self.lang, "cancel_requested"))
            self.log(tr(self.lang, "cancel_requested"))

    # ========================================================
    # Settings
    # ========================================================
    def speed_settings(self):
        profile = option_key("speed", self.speed_var.get(), self.lang)
        if profile == "gentle":
            return {
                "direct_chunk": 1024 * 1024,
                "yt_fragments": 4,
                "timeout": (60, 180),
                "direct_threads": 2,
                "mega_chunk": 1024 * 1024 * 2,
            }
        if profile == "fast":
            return {
                "direct_chunk": 1024 * 1024 * 8,
                "yt_fragments": 16,
                "timeout": (90, 300),
                "direct_threads": 8,
                "mega_chunk": 1024 * 1024 * 16,
            }
        return {
            "direct_chunk": 1024 * 1024 * 4,
            "yt_fragments": 10,
            "timeout": (60, 300),
            "direct_threads": 4,
            "mega_chunk": 1024 * 1024 * 8,
        }

    def wants_mp3_output(self) -> bool:
        quality_key = option_key("quality", self.quality_var.get(), self.lang)
        output_key = option_key("output", self.output_var.get(), self.lang)
        return quality_key == "audio_mp3" or output_key == "mp3"

    def ensure_ffmpeg_for_mp3(self):
        if not self.ffmpeg_path:
            raise RuntimeError(tr(self.lang, "mp3_requires_ffmpeg"))

    def convert_to_mp3(self, source_path: Path, final_path: Path | None = None) -> Path:
        self.ensure_ffmpeg_for_mp3()
        source_path = Path(source_path)
        if final_path is None:
            final_path = unique_path(source_path.with_suffix(".mp3"))
        else:
            final_path = unique_path(Path(final_path))

        if source_path.suffix.lower() == ".mp3":
            if source_path.resolve() != final_path.resolve():
                shutil.move(str(source_path), str(final_path))
            return final_path

        self.q.put(("status", tr(self.lang, "mp3_conversion_start")))
        self.q.put(("log", f"{tr(self.lang, 'mp3_conversion_start')} {source_path.name}"))

        cmd = [
            self.ffmpeg_path,
            "-y",
            "-i", str(source_path),
            "-vn",
            "-map", "0:a:0?",
            "-codec:a", "libmp3lame",
            "-b:a", "192k",
            str(final_path),
        ]
        result = subprocess.run(
            cmd,
            text=True,
            capture_output=True,
            encoding="utf-8",
            errors="replace",
            creationflags=subprocess.CREATE_NO_WINDOW if os.name == "nt" else 0,
        )
        if result.returncode != 0 or not final_path.exists() or final_path.stat().st_size == 0:
            final_path.unlink(missing_ok=True)
            err = (result.stderr or result.stdout or "FFmpeg failed").strip()
            raise RuntimeError(err[-900:])

        try:
            source_path.unlink(missing_ok=True)
        except Exception:
            pass

        self.q.put(("log", f"{tr(self.lang, 'mp3_conversion_done')}: {final_path}"))
        self.q.put(("status", tr(self.lang, "mp3_conversion_done")))
        return final_path

    def ytdlp_format(self):
        q = option_key("quality", self.quality_var.get(), self.lang)
        out_ext = option_key("output", self.output_var.get(), self.lang)

        if q == "audio_mp3" or out_ext == "mp3":
            return "bestaudio/best"
        if q == "1080p":
            return "bv*[height<=1080]+ba/b[height<=1080]/best[height<=1080]"
        if q == "720p":
            return "bv*[height<=720]+ba/b[height<=720]/best[height<=720]"
        if q == "480p":
            return "bv*[height<=480]+ba/b[height<=480]/best[height<=480]"
        return "bv*+ba/best"

    # ========================================================
    # Link check
    # ========================================================
    def check_link(self):
        url = self.url_entry.get().strip()
        if not valid_url(url):
            self.show_toast(tr(self.lang, "invalid_link_title"), tr(self.lang, "invalid_link_message"), kind="error")
            return
        if self.is_downloading:
            return

        self.check_button.configure(state="disabled")
        self.set_status(tr(self.lang, "checking_link"))
        self.log(f"{tr(self.lang, 'checking_link')} {url}")

        threading.Thread(target=self.check_worker, args=(url,), daemon=True).start()

    def check_worker(self, url):
        try:
            mode = option_key("mode", self.mode_var.get(), self.lang)
            if is_mega_url(url) or is_mega_folder_url(url):
                self.check_mega(url)
            elif mode == "direct" or (mode == "auto" and is_direct_file_url(url)):
                self.check_direct(url)
            else:
                self.check_ytdlp(url)
        except Exception as e:
            self.q.put(("log", f"{tr(self.lang, 'check_failed')} {e}"))
            self.q.put(("status", tr(self.lang, "check_failed")))
        finally:
            self.q.put(("enable_check", None))

    def check_direct(self, url):
        headers = {
            "User-Agent": "Mozilla/5.0",
            "Accept": "*/*",
            "Connection": "keep-alive",
        }
        timeout = self.speed_settings()["timeout"]

        try:
            r = requests.head(url, allow_redirects=True, timeout=timeout, headers=headers)
            final_url = r.url or url
            headers_info = r.headers
        except Exception as e:
            self.q.put(("log", f"HEAD failed, using GET fallback: {e}"))
            with requests.get(url, stream=True, timeout=timeout, headers=headers, allow_redirects=True) as r:
                r.raise_for_status()
                final_url = r.url or url
                headers_info = r.headers

        size = headers_info.get("content-length")
        ctype = headers_info.get("content-type", "?")
        name = filename_from_url(final_url)

        size_text = tr(self.lang, "unknown_size")
        if size and str(size).isdigit():
            size_text = f"{int(size) / 1024 / 1024:.2f} MB"

        self.q.put(("log", f"{tr(self.lang, 'direct_check_ok')} {name}"))
        self.q.put(("log", f"Typ: {ctype} | {tr(self.lang, 'mega_size')}: {size_text}"))
        self.q.put(("status", tr(self.lang, "direct_check_ok")))

    def check_mega(self, url):
        if is_mega_folder_url(url):
            self.q.put(("log", tr(self.lang, "mega_folder_unsupported")))
            self.q.put(("status", tr(self.lang, "mega_folder_status")))
            return

        if not HAS_CRYPTO:
            self.q.put(("log", tr(self.lang, "mega_missing_status")))
            self.q.put(("status", tr(self.lang, "mega_missing_status")))
            self.q.put(("error", "pycryptodome missing. Install with: pip install pycryptodome"))
            return

        file_id, file_key_string = parse_mega_file_url(url)
        if not file_id or not file_key_string:
            self.q.put(("log", tr(self.lang, "mega_invalid")))
            self.q.put(("status", tr(self.lang, "mega_invalid_status")))
            return

        file_key, _nonce = mega_file_key_and_nonce(file_key_string)

        api_url = "https://g.api.mega.co.nz/cs"
        payload = [{"a": "g", "g": 1, "p": file_id}]
        response = requests.post(api_url, params={"id": int(time.time() * 1000) % 1000000}, json=payload, timeout=30)
        response.raise_for_status()
        data = response.json()[0]

        if isinstance(data, int):
            raise RuntimeError(f"MEGA API error: {data}")

        size = int(data.get("s", 0) or 0)
        attrs = mega_decrypt_attributes(data.get("at", ""), file_key)
        name = attrs.get("n", "mega_download.bin")

        self.q.put(("log", f"{tr(self.lang, 'mega_file_detected')}: {name}"))
        if size:
            self.q.put(("log", f"{tr(self.lang, 'mega_size')}: {size / 1024 / 1024:.2f} MB"))
        self.q.put(("status", tr(self.lang, "mega_status_ok")))

    def check_ytdlp(self, url):
        if not self.ytdlp_path:
            self.q.put(("log", tr(self.lang, "ytdlp_missing_long")))
            self.q.put(("status", tr(self.lang, "ytdlp_missing")))
            return

        cmd = [
            self.ytdlp_path,
            "--dump-single-json",
            "--no-warnings",
            "--socket-timeout", "60",
        ]

        if not self.playlist_var.get():
            cmd.append("--no-playlist")

        cmd.append(url)

        result = subprocess.run(
            cmd,
            text=True,
            capture_output=True,
            encoding="utf-8",
            errors="replace",
            timeout=90,
            creationflags=subprocess.CREATE_NO_WINDOW if os.name == "nt" else 0,
        )

        if result.returncode != 0:
            err = (result.stderr or result.stdout or "").strip()
            self.q.put(("log", f"{tr(self.lang, 'ytdlp_info_error')}: {err[:600]}"))
            self.q.put(("status", tr(self.lang, "check_failed")))
            return

        try:
            info = json.loads(result.stdout)
        except Exception:
            self.q.put(("log", "yt-dlp returned invalid JSON."))
            self.q.put(("status", tr(self.lang, "link_check_no_info")))
            return

        if isinstance(info, dict) and "entries" in info:
            entries = [e for e in info.get("entries", []) if e]
            self.q.put(("log", f"{tr(self.lang, 'playlist_detected')}: {info.get('title', 'Untitled')}"))
            self.q.put(("log", f"{tr(self.lang, 'entries')}: {len(entries)}"))
            self.q.put(("status", f"{tr(self.lang, 'playlist_detected')}: {len(entries)}"))
            return

        title = info.get("title", "Untitled") if isinstance(info, dict) else "Unknown"
        duration = seconds_to_text(info.get("duration")) if isinstance(info, dict) else "?"
        uploader = (info.get("uploader") or info.get("channel") or "?") if isinstance(info, dict) else "?"

        self.q.put(("log", f"{tr(self.lang, 'title')}: {title}"))
        self.q.put(("log", f"{tr(self.lang, 'duration')}: {duration} | {tr(self.lang, 'uploader')}: {uploader}"))
        self.q.put(("status", tr(self.lang, "link_detected")))

    # ========================================================
    # Download
    # ========================================================
    def start_download(self):
        url = self.url_entry.get().strip()
        if not valid_url(url):
            self.show_toast(tr(self.lang, "invalid_link_title"), tr(self.lang, "invalid_link_message"), kind="error")
            return

        folder = self.folder_entry.get().strip() or self.download_dir
        Path(folder).mkdir(parents=True, exist_ok=True)

        self.set_downloading_ui(True)
        self.set_status(tr(self.lang, "download_starting"))
        self.log(f"{tr(self.lang, 'download_starting')} {url}")

        threading.Thread(target=self.download_worker, args=(url, folder), daemon=True).start()

    def download_worker(self, url, folder):
        try:
            mode = option_key("mode", self.mode_var.get(), self.lang)

            if is_mega_url(url) or is_mega_folder_url(url):
                self.download_mega(url, folder)
            elif mode == "direct":
                self.download_direct(url, folder)
            elif mode == "ytdlp":
                self.download_ytdlp(url, folder)
            else:
                if is_direct_file_url(url):
                    self.download_direct(url, folder)
                else:
                    self.download_ytdlp(url, folder)

            if self.cancel_requested:
                raise CancelDownload(tr(self.lang, "cancelled"))

            self.q.put(("progress", 1))
            self.q.put(("status", tr(self.lang, "finished")))
            self.q.put(("log", tr(self.lang, "download_done")))
            self.q.put(("info", tr(self.lang, "download_done")))

        except CancelDownload as e:
            self.q.put(("status", tr(self.lang, "cancelled")))
            self.q.put(("log", str(e)))

        except Exception as e:
            self.q.put(("status", tr(self.lang, "error")))
            self.q.put(("log", f"{tr(self.lang, 'error')}: {e}"))
            self.q.put(("error", str(e)))

        finally:
            self.q.put(("done", None))

    def download_mega(self, url, folder):
        if is_mega_folder_url(url):
            raise RuntimeError(tr(self.lang, "mega_folder_unsupported"))

        if not HAS_CRYPTO:
            raise RuntimeError("pycryptodome missing. Install with: pip install pycryptodome")

        file_id, file_key_string = parse_mega_file_url(url)
        if not file_id or not file_key_string:
            raise RuntimeError(tr(self.lang, "mega_invalid"))

        file_key, nonce = mega_file_key_and_nonce(file_key_string)

        api_url = "https://g.api.mega.co.nz/cs"
        payload = [{"a": "g", "g": 1, "p": file_id}]
        response = requests.post(api_url, params={"id": int(time.time() * 1000) % 1000000}, json=payload, timeout=30)
        response.raise_for_status()
        data = response.json()[0]

        if isinstance(data, int):
            raise RuntimeError(f"MEGA API error: {data}")

        download_url = data.get("g")
        if not download_url:
            raise RuntimeError("MEGA download URL could not be fetched.")

        size = int(data.get("s", 0) or 0)
        attrs = mega_decrypt_attributes(data.get("at", ""), file_key)
        name = safe_filename(attrs.get("n", "mega_download.bin"), "mega_download.bin")
        mp3_requested = self.wants_mp3_output()
        if mp3_requested:
            self.ensure_ffmpeg_for_mp3()
            self.q.put(("log", tr(self.lang, "mp3_output_enabled")))
            raw_suffix = Path(name).suffix or ".bin"
            download_output = unique_path(Path(folder) / (Path(name).stem + ".clipvault_tmp" + raw_suffix))
            final_mp3_output = Path(folder) / (safe_filename(Path(name).stem, "mega_download") + ".mp3")
        else:
            download_output = unique_path(Path(folder) / name)
            final_mp3_output = None
        output = download_output

        self.q.put(("status", tr(self.lang, "mega_running")))
        self.q.put(("log", f"{tr(self.lang, 'saving_as')}: {output.name}"))

        cipher = AES.new(file_key, AES.MODE_CTR, nonce=nonce, initial_value=0)

        settings = self.speed_settings()
        mega_chunk = settings.get("mega_chunk", 1024 * 1024 * 8)

        headers = {
            "User-Agent": "Mozilla/5.0",
            "Accept": "*/*",
            "Connection": "keep-alive",
        }

        self.q.put(("log", f"{tr(self.lang, 'mega_speed_profile')}: {self.speed_var.get()} | Chunk: {mega_chunk // 1024 // 1024} MB"))

        session = requests.Session()
        with session.get(download_url, stream=True, timeout=settings.get("timeout", (30, 300)), headers=headers, allow_redirects=True) as r:
            r.raise_for_status()

            downloaded = 0
            start_time = time.time()

            with open(output, "wb", buffering=1024 * 1024 * 8) as f:
                for chunk in r.iter_content(chunk_size=mega_chunk):
                    if self.cancel_requested:
                        try:
                            f.close()
                            output.unlink(missing_ok=True)
                        except Exception:
                            pass
                        raise CancelDownload(tr(self.lang, "cancelled"))

                    if not chunk:
                        continue

                    decrypted = cipher.decrypt(chunk)
                    f.write(decrypted)
                    downloaded += len(chunk)

                    elapsed = max(time.time() - start_time, 0.1)
                    speed = downloaded / elapsed
                    percent = downloaded / size if size else 0
                    eta = (size - downloaded) / speed if size and speed else None

                    self.q.put(("progress", max(0, min(percent, 1))))
                    if size:
                        self.q.put(("status", f"MEGA {percent * 100:.1f}% | {speed / 1024 / 1024:.2f} MB/s | ETA {seconds_to_text(eta)}"))
                    else:
                        self.q.put(("status", f"MEGA {downloaded / 1024 / 1024:.2f} MB | {speed / 1024 / 1024:.2f} MB/s"))

        if size and output.exists() and output.stat().st_size != size:
            raise RuntimeError(f"MEGA size mismatch: expected {size} bytes, got {output.stat().st_size} bytes")

        if mp3_requested:
            output = self.convert_to_mp3(download_output, final_mp3_output)

        self.q.put(("log", f"{tr(self.lang, 'mega_saved')}: {output}"))

    def download_direct(self, url, folder):
        settings = self.speed_settings()
        headers = {
            "User-Agent": "Mozilla/5.0",
            "Accept": "*/*",
            "Connection": "keep-alive",
        }

        self.q.put(("status", tr(self.lang, "direct_running")))

        final_url = url
        total = 0
        content_type = ""

        try:
            head = requests.head(url, allow_redirects=True, timeout=settings["timeout"], headers=headers)
            final_url = head.url or url
            total = int(head.headers.get("content-length", 0) or 0)
            content_type = head.headers.get("content-type", "").lower()
        except Exception as e:
            self.q.put(("log", f"HEAD failed, using GET metadata fallback: {e}"))

        name = filename_from_url(final_url)
        if "." not in name:
            if "mp4" in content_type:
                name += ".mp4"
            elif "webm" in content_type:
                name += ".webm"
            elif "matroska" in content_type or "mkv" in content_type:
                name += ".mkv"
            elif "audio" in content_type:
                name += ".mp3"
            else:
                name += ".bin"

        if self.clean_names_var.get():
            name = safe_filename(Path(name).stem) + Path(name).suffix

        mp3_requested = self.wants_mp3_output()
        if mp3_requested:
            self.ensure_ffmpeg_for_mp3()
            self.q.put(("log", tr(self.lang, "mp3_output_enabled")))
            raw_suffix = Path(name).suffix or ".bin"
            output = unique_path(Path(folder) / (Path(name).stem + ".clipvault_tmp" + raw_suffix))
            final_mp3_output = Path(folder) / (safe_filename(Path(name).stem, "download") + ".mp3")
        else:
            output = unique_path(Path(folder) / name)
            final_mp3_output = None

        threads = settings["direct_threads"]

        if total > 10 * 1024 * 1024 and threads > 1 and server_supports_ranges(final_url, headers, settings["timeout"]):
            self.q.put(("log", f"{tr(self.lang, 'turbo_active')}: {threads}"))
            self.download_direct_multipart(final_url, output, total, headers, settings)
            if mp3_requested:
                output = self.convert_to_mp3(output, final_mp3_output)
                self.q.put(("log", f"{tr(self.lang, 'saved')}: {output}"))
            return

        self.q.put(("log", tr(self.lang, "turbo_unavailable")))
        with requests.get(
            final_url,
            stream=True,
            timeout=settings["timeout"],
            headers=headers,
            allow_redirects=True,
        ) as r:
            r.raise_for_status()

            if not total:
                total = int(r.headers.get("content-length", 0) or 0)
            if content_type == "":
                content_type = r.headers.get("content-type", "").lower()

            downloaded = 0
            start_time = time.time()
            self.q.put(("log", f"{tr(self.lang, 'saving_as')}: {output.name}"))

            with open(output, "wb") as f:
                for chunk in r.iter_content(chunk_size=settings["direct_chunk"]):
                    if self.cancel_requested:
                        try:
                            f.close()
                            output.unlink(missing_ok=True)
                        except Exception:
                            pass
                        raise CancelDownload(tr(self.lang, "cancelled"))

                    if not chunk:
                        continue

                    f.write(chunk)
                    downloaded += len(chunk)

                    elapsed = max(time.time() - start_time, 0.1)
                    speed = downloaded / elapsed
                    percent = downloaded / total if total else 0
                    eta = (total - downloaded) / speed if total and speed else None

                    self.q.put(("progress", max(0, min(percent, 1))))
                    if total:
                        self.q.put(("status", f"{percent * 100:.1f}% | {speed / 1024 / 1024:.2f} MB/s | ETA {seconds_to_text(eta)}"))
                    else:
                        self.q.put(("status", f"{downloaded / 1024 / 1024:.2f} MB | {speed / 1024 / 1024:.2f} MB/s"))

        if total and output.exists() and output.stat().st_size != total:
            raise RuntimeError(f"Size mismatch: expected {total} bytes, got {output.stat().st_size} bytes")

        if mp3_requested:
            output = self.convert_to_mp3(output, final_mp3_output)

        self.q.put(("log", f"{tr(self.lang, 'saved')}: {output}"))

    def download_direct_multipart(self, url, output: Path, total: int, headers: dict, settings: dict):
        temp_dir = Path(tempfile.mkdtemp(prefix="clipvault_parts_"))
        threads_count = max(1, int(settings["direct_threads"]))
        part_size = total // threads_count
        downloaded_parts = [0 for _ in range(threads_count)]
        errors = []
        start_time = time.time()
        cancel_event = threading.Event()

        self.q.put(("log", f"{tr(self.lang, 'saving_as')}: {output.name}"))
        self.q.put(("log", f"{tr(self.lang, 'filesize')}: {total / 1024 / 1024:.2f} MB"))

        def worker(index: int, start_byte: int, end_byte: int):
            part_path = temp_dir / f"part_{index}.tmp"
            local_headers = dict(headers)
            local_headers["Range"] = f"bytes={start_byte}-{end_byte}"
            expected_len = end_byte - start_byte + 1

            try:
                with requests.get(
                    url,
                    stream=True,
                    timeout=settings["timeout"],
                    headers=local_headers,
                    allow_redirects=True,
                ) as r:
                    if r.status_code != 206:
                        raise RuntimeError(f"Part {index + 1}: server ignored Range request (HTTP {r.status_code})")

                    with open(part_path, "wb") as f:
                        for chunk in r.iter_content(chunk_size=settings["direct_chunk"]):
                            if self.cancel_requested or cancel_event.is_set():
                                raise CancelDownload(tr(self.lang, "cancelled"))
                            if not chunk:
                                continue
                            f.write(chunk)
                            downloaded_parts[index] += len(chunk)

                if part_path.exists() and part_path.stat().st_size != expected_len:
                    raise RuntimeError(f"Part {index + 1}: size mismatch")
            except Exception as e:
                cancel_event.set()
                errors.append(e)

        threads = []
        for i in range(threads_count):
            start_byte = i * part_size
            end_byte = total - 1 if i == threads_count - 1 else ((i + 1) * part_size - 1)
            t = threading.Thread(target=worker, args=(i, start_byte, end_byte), daemon=True)
            threads.append(t)
            t.start()

        while any(t.is_alive() for t in threads):
            if self.cancel_requested or cancel_event.is_set():
                cancel_event.set()

            downloaded = sum(downloaded_parts)
            elapsed = max(time.time() - start_time, 0.1)
            speed = downloaded / elapsed
            percent = downloaded / total if total else 0
            eta = (total - downloaded) / speed if total and speed else None

            self.q.put(("progress", max(0, min(percent, 1))))
            self.q.put(("status", f"Turbo {percent * 100:.1f}% | {speed / 1024 / 1024:.2f} MB/s | ETA {seconds_to_text(eta)}"))
            time.sleep(0.4)

        for t in threads:
            t.join()

        if self.cancel_requested:
            shutil.rmtree(temp_dir, ignore_errors=True)
            output.unlink(missing_ok=True)
            raise CancelDownload(tr(self.lang, "cancelled"))

        if errors:
            shutil.rmtree(temp_dir, ignore_errors=True)
            raise RuntimeError(f"Turbo download error: {errors[0]}")

        self.q.put(("status", tr(self.lang, "combining_parts")))
        with open(output, "wb") as out:
            for i in range(threads_count):
                part_path = temp_dir / f"part_{i}.tmp"
                if not part_path.exists():
                    raise RuntimeError(f"Missing part {i + 1}")
                with open(part_path, "rb") as part:
                    shutil.copyfileobj(part, out, length=1024 * 1024 * 8)

        shutil.rmtree(temp_dir, ignore_errors=True)

        if output.exists() and output.stat().st_size != total:
            output.unlink(missing_ok=True)
            raise RuntimeError(f"Final size mismatch: expected {total} bytes, got {output.stat().st_size} bytes")

        self.q.put(("progress", 1))
        self.q.put(("log", f"{tr(self.lang, 'saved')}: {output}"))

    def download_ytdlp(self, url, folder):
        if not self.ytdlp_path:
            raise RuntimeError(tr(self.lang, "ytdlp_missing_long"))

        settings = self.speed_settings()
        quality_key = option_key("quality", self.quality_var.get(), self.lang)
        out_ext = option_key("output", self.output_var.get(), self.lang)

        self.q.put(("status", tr(self.lang, "yt_running")))

        outtmpl = "%(title).180s [%(id)s].%(ext)s" if self.clean_names_var.get() else "%(id)s.%(ext)s"
        out_path_template = os.path.join(folder, outtmpl)

        cmd = [
            self.ytdlp_path,
            "-f", self.ytdlp_format(),
            "-o", out_path_template,
            "--newline",
            "--no-warnings",
            "--retries", "8",
            "--fragment-retries", "8",
            "--continue",
            "--windows-filenames",
            "--concurrent-fragments", str(settings["yt_fragments"]),
            "--socket-timeout", "60",
        ]

        if not self.playlist_var.get():
            cmd.append("--no-playlist")

        if self.ffmpeg_path:
            ffmpeg_location = str(Path(self.ffmpeg_path).parent)
            cmd.extend(["--ffmpeg-location", ffmpeg_location])

        if quality_key == "audio_mp3" or out_ext == "mp3":
            self.ensure_ffmpeg_for_mp3()
            self.q.put(("log", tr(self.lang, "mp3_output_enabled")))
            cmd.extend(["-x", "--audio-format", "mp3", "--audio-quality", "192K"])
        else:
            cmd.extend(["--merge-output-format", out_ext])

        cmd.append(url)

        process = subprocess.Popen(
            cmd,
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            text=True,
            encoding="utf-8",
            errors="replace",
            creationflags=subprocess.CREATE_NO_WINDOW if os.name == "nt" else 0,
        )

        last_log = time.time()

        try:
            for line in process.stdout:
                if self.cancel_requested:
                    try:
                        process.terminate()
                        process.wait(timeout=5)
                    except Exception:
                        try:
                            process.kill()
                        except Exception:
                            pass
                    raise CancelDownload(tr(self.lang, "cancelled"))

                line = line.strip()
                if not line:
                    continue

                if "[download]" in line:
                    match = re.search(r"(\d+(?:\.\d+)?)%", line)
                    if match:
                        percent = float(match.group(1)) / 100.0
                        self.q.put(("progress", max(0.0, min(percent, 1.0))))

                    clean_line = re.sub(r"\s+", " ", line)
                    self.q.put(("status", clean_line[:180]))

                    now = time.time()
                    if now - last_log > 5:
                        last_log = now
                        self.q.put(("log", clean_line[:300]))

                elif "has already been downloaded" in line.lower():
                    self.q.put(("log", line[:300]))

                elif "error" in line.lower():
                    self.q.put(("log", line[:500]))

            return_code = process.wait()

            if return_code != 0:
                raise RuntimeError(f"{tr(self.lang, 'yt_error_exit')}: {return_code}")

            self.q.put(("progress", 1))
            self.q.put(("log", tr(self.lang, "yt_done")))

        finally:
            try:
                if process.poll() is None:
                    process.terminate()
            except Exception:
                pass

    # ========================================================
    # Queue
    # ========================================================
    def process_queue(self):
        try:
            while True:
                typ, payload = self.q.get_nowait()

                if typ == "log":
                    self.log(str(payload))
                elif typ == "status":
                    self.set_status(str(payload))
                elif typ == "progress":
                    self.progress.set(float(payload))
                elif typ == "done":
                    self.set_downloading_ui(False)
                elif typ == "enable_check":
                    self.check_button.configure(state="normal")
                elif typ == "error":
                    self.show_toast(tr(self.lang, "error"), str(payload), kind="error", duration=4200)
                elif typ == "info":
                    self.show_toast(tr(self.lang, "info"), str(payload), kind="info", duration=3200)

                elif typ == "connection":
                    self.internet_check_running = False
                    self.update_connection_badge(bool(payload))
                elif typ == "refresh_deps":
                    self.refresh_dependency_paths()
                elif typ == "requirements_done":
                    self.requirements_install_running = False
                    if hasattr(self, "btn_requirements"):
                        self.btn_requirements.configure(state="normal", text="⬇  " + tr(self.lang, "requirements"))

        except queue.Empty:
            pass

        self.after(200, self.process_queue)


if __name__ == "__main__":
    login = LoginWindow()
    login.mainloop()

    authenticated = getattr(login, "authenticated", False)
    selected_language = getattr(login, "selected_language", "English")

    if authenticated:
        app = ClipVaultApp()
        app.lang = selected_language
        app.lang_var.set(app.lang)
        app.change_app_language(app.lang)
        app.mainloop()
