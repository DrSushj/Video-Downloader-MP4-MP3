        "gentle": {"English": "Gentle", "Deutsch": "Schonend", "Spanish": "Suave", "Italian": "Leggero", "French": "Doux"},
        "normal": {"English": "Normal", "Deutsch": "Normal", "Spanish": "Normal", "Italian": "Normale", "French": "Normal"},
        "fast": {"English": "Fast", "Deutsch": "Schnell", "Spanish": "Rápido", "Italian": "Veloce", "French": "Rapide"},
    },
}

def tr(lang: str, key: str) -> str:
    return TR.get(lang, TR["English"]).get(key, TR["English"].get(key, key))

def option_label(group: str, key: str, lang: str) -> str:
    data = OPTION_TEXT[group][key]
    return data.get(lang, data.get("English", key))

def option_values(group: str, lang: str) -> list[str]:
    return [option_label(group, key, lang) for key in OPTION_TEXT[group]]

def option_key(group: str, value: str, lang: str | None = None) -> str:
    value = str(value or "").strip()
    if not value:
        return next(iter(OPTION_TEXT[group]))

    for key, translations in OPTION_TEXT[group].items():
        if value == key:
            return key
        for translated in translations.values():
            if value.lower() == translated.lower():
                return key

    normalized = value.lower()
    aliases = {
        "mode": {
            "auto": "auto",
            "direkter datei-link": "direct",
            "direct file link": "direct",
            "webseite / yt-dlp": "ytdlp",
            "website / yt-dlp": "ytdlp",
        },
        "quality": {
            "bestes video": "best",
            "best video": "best",
            "nur audio mp3": "audio_mp3",
            "audio mp3 only": "audio_mp3",
        },
        "speed": {
            "schonend": "gentle",
            "gentle": "gentle",
            "schnell": "fast",
            "fast": "fast",
            "normal": "normal",
        },
        "output": {
            "mp4": "mp4",
            "mkv": "mkv",
            "webm": "webm",
            "mp3": "mp3",
        },
    }
    return aliases.get(group, {}).get(normalized, next(iter(OPTION_TEXT[group])))


def normalize_key(key: str) -> str:
    raw = re.sub(r"[^A-Za-z0-9]", "", key or "").upper()
    if len(raw) == 12:
        return f"{raw[0:4]}-{raw[4:8]}-{raw[8:12]}"
    return (key or "").strip().upper()


def is_valid_key(key: str) -> tuple[bool, str]:
    """
    Online license check via Cloudflare Worker.
    If online check succeeds, a 30-day offline cache is saved locally.
    If internet/server is unavailable, the app can start with a valid offline cache.
    """
    normalized = normalize_key(key)
    raw = re.sub(r"[^A-Za-z0-9]", "", normalized).upper()

    if len(raw) != 12:
        return False, "Invalid key format."

    try:
        response = requests.post(
            LICENSE_API_URL,
            json={"key": normalized},
            timeout=12,
            headers={"Content-Type": "application/json"},
        )
        response.raise_for_status()
        data = response.json()

        if data.get("ok") is True and data.get("valid") is True:
            save_offline_license(normalized)
            return True, "Login successful. Offline access saved for 30 days."

        return False, data.get("error") or "Invalid license key."

    except (requests.exceptions.Timeout, requests.exceptions.ConnectionError):
        offline_valid, offline_message = load_offline_license()
        if offline_valid:
            return True, offline_message
        return False, "No connection to license server and no valid offline cache."

    except Exception as exc:
        offline_valid, offline_message = load_offline_license()
        if offline_valid:
            return True, offline_message
        return False, f"License check failed: {exc}"




def app_dir() -> Path:
    return Path(__file__).resolve().parent


def find_local_or_path_exe(name: str):
    local = app_dir() / name
    if local.exists():
        return str(local)
    found = shutil.which(name)
    return found


def find_ytdlp_exe():
    candidates = [
        "yt-dlp.exe",
        "yt-dlp",
        "yt_dlp.exe",
    ]

    for candidate in candidates:
        found = find_local_or_path_exe(candidate)
        if found:
            return found

    return None


def safe_filename(name: str, fallback: str = "download") -> str:
    name = unquote(name or "")
    name = re.sub(r'[<>:"/\\|?*\x00-\x1f]', "_", name)
    name = re.sub(r"\s+", " ", name).strip()
    return (name[:180] or fallback)


def valid_url(url: str) -> bool:
    return bool(re.match(r"^https?://", url.strip(), re.IGNORECASE))


def is_direct_file_url(url: str) -> bool:
    path = urlparse(url).path.lower()
    return path.endswith(DIRECT_VIDEO_EXTENSIONS + DIRECT_AUDIO_EXTENSIONS)


def filename_from_url(url: str) -> str:
    parsed = urlparse(url)
    name = Path(unquote(parsed.path)).name
    return safe_filename(name, "video_download")


def seconds_to_text(sec):
    if sec is None:
        return "?"
    try:
        sec = int(sec)
    except Exception:
        return "?"
    h = sec // 3600
    m = (sec % 3600) // 60
    s = sec % 60
    if h:
        return f"{h}h {m}m {s}s"
    if m:
        return f"{m}m {s}s"
    return f"{s}s"


def unique_path(path: Path) -> Path:
    if not path.exists():
        return path
    stem = path.stem
    suffix = path.suffix
    parent = path.parent
    i = 1
    while True:
        new = parent / f"{stem}_{i}{suffix}"
        if not new.exists():
            return new
        i += 1


def server_supports_ranges(url: str, headers: dict, timeout) -> bool:
    try:
        test_headers = dict(headers)
        test_headers["Range"] = "bytes=0-0"
        r = requests.get(url, headers=test_headers, timeout=timeout, stream=True, allow_redirects=True)
        try:
            return r.status_code == 206
        finally:
            r.close()
    except Exception:
        return False


class CancelDownload(Exception):
    pass




class HoverInfo:
    def __init__(self, widget, text_func, delay=350):
        self.widget = widget
        self.text_func = text_func
        self.delay = delay
        self.tip = None
        self.after_id = None

        self.widget.bind("<Enter>", self.on_enter, add="+")
        self.widget.bind("<Leave>", self.on_leave, add="+")
        self.widget.bind("<ButtonPress>", self.on_leave, add="+")
        self.widget.bind("<Destroy>", self.on_leave, add="+")

    def on_enter(self, _event=None):
        self.cancel()
        self.after_id = self.widget.after(self.delay, self.show)

    def on_leave(self, _event=None):
        self.cancel()
        self.hide()

    def cancel(self):
        if self.after_id:
            try:
                self.widget.after_cancel(self.after_id)
            except Exception:
                pass
            self.after_id = None

    def show(self):
        self.hide()
        try:
            message = self.text_func() if callable(self.text_func) else str(self.text_func)
        except Exception:
            message = ""
        if not message:
            return

        self.tip = ctk.CTkToplevel(self.widget)
        self.tip.overrideredirect(True)
        self.tip.attributes("-topmost", True)
        self.tip.configure(fg_color="#111116")

        x = self.widget.winfo_rootx() + self.widget.winfo_width() + 10
        y = self.widget.winfo_rooty() - 4
        self.tip.geometry(f"+{x}+{y}")

        frame = ctk.CTkFrame(
            self.tip,
            corner_radius=14,
            fg_color="#111116",
            border_width=1,
            border_color=BORDER,
        )
        frame.pack(fill="both", expand=True)

        label = ctk.CTkLabel(
            frame,
            text=message,
            justify="left",
            wraplength=340,
            text_color="#f1f1f4",
            fg_color="transparent",
            font=ctk.CTkFont(size=12),
            padx=12,
            pady=10,
        )
        label.pack(fill="both", expand=True)

    def hide(self):
        if self.tip is not None:
            try:
                self.tip.destroy()
            except Exception:
                pass
            self.tip = None



class ToastNotification(ctk.CTkToplevel):
    def __init__(self, master, title, message, kind="info", duration=3200, on_close=None, actions=None):
        super().__init__(master)

        self.master_window = master
        self.title_text = title
        self.message_text = message
        self.kind = kind
        self.duration = duration
        self.on_close = on_close
        self.actions = actions or []
        self.hiding = False
        self.visible = False

        self.toast_width = 360
        line_count = max(1, message.count("\n") + 1)
        self.toast_height = 90 + min(2, line_count - 1) * 18

        if kind == "error":
            accent = RED
            title_color = "#ffd9d9"
            icon_text = "✕"
        else:
            accent = "#4ea1ff"
            title_color = "#eaf3ff"
            icon_text = "i"

        self.withdraw()
        self.overrideredirect(True)
        self.resizable(False, False)
        self.attributes("-topmost", True)
        try:
            self.attributes("-alpha", 0.0)
        except Exception:
            pass

        self.configure(fg_color="#111116")

        self.outer = ctk.CTkFrame(
            self,
            width=self.toast_width,
            height=self.toast_height,
            fg_color="#121219",
            corner_radius=16,
            border_width=1,
            border_color=BORDER,
        )
        self.outer.pack(fill="both", expand=True)
        self.outer.pack_propagate(False)

        self.outer.grid_columnconfigure(0, weight=0)
        self.outer.grid_columnconfigure(1, weight=1)
        self.outer.grid_columnconfigure(2, weight=0)

        self.accent_bar = ctk.CTkFrame(
            self.outer,
            width=6,
            corner_radius=16,
            fg_color=accent,
        )
        self.accent_bar.grid(row=0, column=0, sticky="nsw", padx=(0, 12), pady=0)

        self.content = ctk.CTkFrame(self.outer, fg_color="transparent")
        self.content.grid(row=0, column=1, sticky="nsew", padx=(0, 8), pady=10)

        self.title_label = ctk.CTkLabel(
            self.content,
            text=f"{icon_text}  {self.title_text}",
            anchor="w",
            font=ctk.CTkFont(size=13, weight="bold"),
            text_color=title_color,
        )
        self.title_label.pack(anchor="w", pady=(0, 4))

        self.message_label = ctk.CTkLabel(
            self.content,
            text=self.message_text,
            anchor="w",
            justify="left",
            wraplength=270,
            font=ctk.CTkFont(size=12),
            text_color="#f1f1f4",
        )
        self.message_label.pack(anchor="w")

        if self.actions:
            self.actions_frame = ctk.CTkFrame(self.content, fg_color="transparent")
            self.actions_frame.pack(anchor="w", pady=(9, 0))

            for action_index, action in enumerate(self.actions):
                label = action.get("text", "OK")
                callback = action.get("command")
                style = action.get("style", "secondary")

                if style == "primary":
                    fg = GREEN
                    hover = GREEN_HOVER
                    color = "#06130d"
                else:
                    fg = "#282834"
                    hover = "#343445"
                    color = "#f1f1f4"

                btn = ctk.CTkButton(
                    self.actions_frame,
                    text=label,
                    width=74,
                    height=30,
                    corner_radius=10,
                    fg_color=fg,
                    hover_color=hover,
                    text_color=color,
                    font=ctk.CTkFont(size=12, weight="bold"),
                    command=lambda cb=callback: self.run_action(cb),
                )
                btn.grid(row=0, column=action_index, padx=(0, 8))

        self.close_button = ctk.CTkButton(
            self.outer,
            text="✕",
            width=26,
            height=26,
            corner_radius=13,
            fg_color="#23232d",
            hover_color="#2e2e3c",
            text_color="#d8d8df",
            command=self.hide,
        )
        self.close_button.grid(row=0, column=2, sticky="ne", padx=(0, 10), pady=10)

        self.current_x = 0
        self.current_y = 0
        self.target_x = 0
        self.target_y = 0

        self.bind("<Button-1>", lambda _e: self.hide())
        self.outer.bind("<Button-1>", lambda _e: self.hide())
        self.content.bind("<Button-1>", lambda _e: self.hide())
        self.title_label.bind("<Button-1>", lambda _e: self.hide())
        self.message_label.bind("<Button-1>", lambda _e: self.hide())

    def set_target(self, x, y):
        self.target_x = int(x)
        self.target_y = int(y)

        if not self.visible:
            self.current_x = self.target_x + 18
            self.current_y = self.target_y + 28
            self.geometry(f"{self.toast_width}x{self.toast_height}+{self.current_x}+{self.current_y}")
        else:
            self.current_x = self.target_x
            self.current_y = self.target_y
            self.geometry(f"{self.toast_width}x{self.toast_height}+{self.current_x}+{self.current_y}")

    def show(self):
        if self.visible:
            return

        self.visible = True
        self.deiconify()
        self.lift()
        self._animate_in(step=0)

    def _animate_in(self, step=0):
        if self.hiding:
            return

        total_steps = 8
        progress = min(1.0, (step + 1) / total_steps)
        alpha = min(1.0, progress * 1.35)
        new_y = int(self.target_y + (1.0 - progress) * 28)
        new_x = int(self.target_x + (1.0 - progress) * 18)

        try:
            self.attributes("-alpha", alpha)
        except Exception:
            pass

        self.geometry(f"{self.toast_width}x{self.toast_height}+{new_x}+{new_y}")

        if step < total_steps - 1:
            self.after(22, lambda: self._animate_in(step + 1))
        else:
            self.geometry(f"{self.toast_width}x{self.toast_height}+{self.target_x}+{self.target_y}")
            self.after(self.duration, self.hide)

    def hide(self):
        if self.hiding:
            return
        self.hiding = True
        self._animate_out(step=0)

    def _animate_out(self, step=0):
        total_steps = 7
        progress = min(1.0, (step + 1) / total_steps)
        alpha = max(0.0, 1.0 - progress * 1.35)
        new_y = int(self.target_y - progress * 18)
        new_x = int(self.target_x + progress * 10)

        try:
            self.attributes("-alpha", alpha)
        except Exception:
            pass

        self.geometry(f"{self.toast_width}x{self.toast_height}+{new_x}+{new_y}")

        if step < total_steps - 1:
            self.after(24, lambda: self._animate_out(step + 1))
        else:
            try:
                self.destroy()
            except Exception:
                pass
            if callable(self.on_close):
                try:
                    self.on_close(self)
                except Exception:
                    pass



class InAppToast(ctk.CTkFrame):
    def __init__(self, master, title, message, kind="info", duration=3200, on_close=None, actions=None):
        super().__init__(
            master,
            width=360,
            height=132 if actions else 92,
            corner_radius=16,
            fg_color="#121219",
            border_width=1,
            border_color=BORDER,
        )

        self.toast_width = 360
        self.actions = actions or []
        self.toast_height = 132 if self.actions else 92
        self.duration = duration
        self.on_close = on_close
        self.hiding = False
        self.target_x = 0
        self.target_y = 0
        self.hide_start_x = 0
        self.hide_start_y = 0

        if kind == "error":
            accent = RED
            title_color = "#ffd9d9"
            icon_text = "✕"
        else:
            accent = "#4ea1ff"
            title_color = "#eaf3ff"
            icon_text = "i"

        self.grid_columnconfigure(0, weight=0)
        self.grid_columnconfigure(1, weight=1)
        self.grid_columnconfigure(2, weight=0)
        self.grid_rowconfigure(0, weight=1)
        self.grid_propagate(False)

        self.accent_bar = ctk.CTkFrame(self, width=6, corner_radius=16, fg_color=accent)
        self.accent_bar.grid(row=0, column=0, sticky="nsw", padx=(0, 12), pady=0)

        self.content = ctk.CTkFrame(self, fg_color="transparent")
        self.content.grid(row=0, column=1, sticky="nsew", padx=(0, 8), pady=10)

        self.title_label = ctk.CTkLabel(
            self.content,
            text=f"{icon_text}  {title}",
            anchor="w",
            font=ctk.CTkFont(size=13, weight="bold"),
            text_color=title_color,
        )
        self.title_label.pack(anchor="w", pady=(0, 4))

        self.message_label = ctk.CTkLabel(
            self.content,
            text=str(message),
            anchor="w",
            justify="left",
            wraplength=270,
            font=ctk.CTkFont(size=12),
            text_color="#f1f1f4",
        )
        self.message_label.pack(anchor="w")

        self.close_button = ctk.CTkButton(
            self,
            text="✕",
            width=26,
            height=26,
            corner_radius=13,
            fg_color="#23232d",
            hover_color="#2e2e3c",
            text_color="#d8d8df",
            command=self.hide,
        )
        self.close_button.grid(row=0, column=2, sticky="ne", padx=(0, 10), pady=10)

        if not self.actions:
            for widget in (self, self.accent_bar, self.content, self.title_label, self.message_label):
                widget.bind("<Button-1>", lambda _e: self.hide(), add="+")

    def run_action(self, callback):
        if callable(callback):
            try:
                callback()
            except Exception:
                pass
        self.hide()

    def set_target(self, x, y, animated=False):
        if self.hiding:
            return

        self.target_x = int(x)
        self.target_y = int(y)

        if not self.winfo_ismapped() or not animated:
            self.place(x=self.target_x, y=self.target_y)
        else:
            self._move_to_target(0)

    def show(self):
        if self.winfo_ismapped():
            return
        self.place(x=self.target_x + 20, y=self.target_y + 30)
        self.lift()
        self._animate_in(0)

    def _animate_in(self, step):
        if self.hiding or not self.winfo_exists():
            return

        total = 8
        progress = min(1.0, (step + 1) / total)
        x = int(self.target_x + (1.0 - progress) * 20)
        y = int(self.target_y + (1.0 - progress) * 30)
        self.place(x=x, y=y)

        if step < total - 1:
            self.after(22, lambda: self._animate_in(step + 1))
        else:
            self.place(x=self.target_x, y=self.target_y)
            self.after(self.duration, self.hide)

    def _move_to_target(self, step):
        if self.hiding or not self.winfo_exists():
            return

        if step == 0:
            self.move_start_x = self.winfo_x()
            self.move_start_y = self.winfo_y()

        total = 5
        progress = min(1.0, (step + 1) / total)
        x = int(self.move_start_x + (self.target_x - self.move_start_x) * progress)
        y = int(self.move_start_y + (self.target_y - self.move_start_y) * progress)
        self.place(x=x, y=y)

        if step < total - 1:
            self.after(18, lambda: self._move_to_target(step + 1))
        else:
            self.place(x=self.target_x, y=self.target_y)

    def hide(self):
        if self.hiding:
            return

        self.hiding = True

        try:
            self.hide_start_x = self.winfo_x()
            self.hide_start_y = self.winfo_y()
        except Exception:
            self.hide_start_x = self.target_x
            self.hide_start_y = self.target_y

        self._animate_out(0)

    def _animate_out(self, step):
        if not self.winfo_exists():
            return

        total = 8
        progress = min(1.0, (step + 1) / total)

        # Fixed start position prevents jitter while closing.
        x = int(self.hide_start_x + progress * 10)
        y = int(self.hide_start_y - progress * 26)

        self.place(x=x, y=y)

        if step < total - 1:
            self.after(20, lambda: self._animate_out(step + 1))
        else:
            try:
                self.place_forget()
                self.destroy()
            except Exception:
                pass

            if callable(self.on_close):
                try:
                    self.on_close(self)
                except Exception:
                    pass


class LoginWindow(ctk.CTk):
    def __init__(self):
        super().__init__()

        ctk.set_appearance_mode("dark")
        ctk.set_default_color_theme("dark-blue")

        self.selected_language = "English"
        self.authenticated = False

        self.title(f"{APP_NAME} Login")
        self.geometry("580x540")
        self.resizable(False, False)
        self.configure(fg_color=BG)

        self.card = ctk.CTkFrame(
            self,
            corner_radius=28,
            fg_color=CARD,
            border_width=1,
            border_color=BORDER,
        )
        self.card.pack(expand=True, fill="both", padx=34, pady=34)

        self.logo = ctk.CTkLabel(
            self.card,
            text="✦ ClipVault",
            font=ctk.CTkFont(size=30, weight="bold"),
            text_color=TEXT,
        )
        self.logo.pack(pady=(34, 4))

        self.login_connection_badge = ctk.CTkLabel(
            self.card,
            text="● Checking...",
            font=ctk.CTkFont(size=13, weight="bold"),
            text_color="#ffaa33",
            fg_color="#17171d",
            corner_radius=14,
            padx=14,
            pady=7,
        )
        self.login_connection_badge.pack(pady=(6, 4))

        self.title_label = ctk.CTkLabel(
            self.card,
            text=TR[self.selected_language]["login_title"],
            font=ctk.CTkFont(size=22, weight="bold"),
            text_color=TEXT,
        )
        self.title_label.pack(pady=(12, 4))

        self.subtitle_label = ctk.CTkLabel(
            self.card,
            text=TR[self.selected_language]["login_subtitle"],
            font=ctk.CTkFont(size=13),
            text_color=MUTED,
        )
        self.subtitle_label.pack(pady=(0, 18))

        self.language_var = ctk.StringVar(value="English")
        self.language_menu = ctk.CTkOptionMenu(
            self.card,
            values=LANGUAGES,
            variable=self.language_var,
            height=42,
            corner_radius=14,
            fg_color=INPUT,
            button_color="#272735",
            button_hover_color="#343446",
            command=self.change_language,
        )
        self.language_menu.pack(fill="x", padx=42, pady=(0, 14))

        self.key_frame = ctk.CTkFrame(self.card, fg_color="transparent")
        self.key_frame.pack(fill="x", padx=42, pady=(8, 18))

        self.key_entry = ctk.CTkEntry(
            self.key_frame,
            height=58,
            corner_radius=18,
            placeholder_text="",
            fg_color=INPUT,
            border_color="#30303c",
            text_color=TEXT,
            placeholder_text_color="#777784",
            font=ctk.CTkFont(size=18, weight="bold"),
            justify="center",
        )
        self.key_entry.pack(fill="x")

        self.fake_placeholder = ctk.CTkLabel(
            self.key_frame,
            text="XXXX-XXXX-XXXX",
            font=ctk.CTkFont(size=18, weight="bold"),
            text_color="#777784",
            fg_color=INPUT,
        )
        self.fake_placeholder.place(relx=0.5, rely=0.5, anchor="center")
        self.fake_placeholder.bind("<Button-1>", lambda event: self.key_entry.focus_set())

        self.key_entry.bind("<Return>", lambda event: self.try_login())
        self.key_entry.bind("<KeyRelease>", self.format_key_live)
        self.key_entry.bind("<FocusIn>", lambda event: self.update_fake_placeholder())
        self.key_entry.bind("<FocusOut>", lambda event: self.update_fake_placeholder())

        self.status_label = ctk.CTkLabel(
            self.card,
            text="",
            font=ctk.CTkFont(size=13),
            text_color=RED,
        )
        self.status_label.pack(pady=(0, 16))

        self.login_button = ctk.CTkButton(
            self.card,
            text=TR[self.selected_language]["login_button"],
            height=68,
            corner_radius=20,
            fg_color=GREEN,
            hover_color=GREEN_HOVER,
            text_color="#06130d",
            font=ctk.CTkFont(size=20, weight="bold"),
            command=self.try_login,
        )
        self.login_button.pack(fill="x", padx=30, pady=(0, 28))

        self.footer = ctk.CTkLabel(
            self.card,
            text="",
            font=ctk.CTkFont(size=12),
            text_color="#777784",
        )
        self.footer.pack()

        self.protocol("WM_DELETE_WINDOW", self.safe_close)
        self.login_connection_running = False
        self.login_connection_active = True
        self.start_login_connection_monitor()
        self.after(100, self.key_entry.focus_set)

    def update_login_connection_badge(self, online: bool | None):
        if online is True:
            self.login_connection_badge.configure(text="● Online", text_color=GREEN)
        elif online is False:
            self.login_connection_badge.configure(text="● Offline", text_color=RED)
        else:
            self.login_connection_badge.configure(text="● Checking...", text_color="#ffaa33")

    def start_login_connection_monitor(self):
        self.update_login_connection_badge(None)
        self.check_login_connection_async()

    def check_login_connection_async(self):
        if not getattr(self, "login_connection_active", False):
            return

        if self.login_connection_running:
            self.after(10000, self.check_login_connection_async)
            return

        self.login_connection_running = True

        def worker():
            online = has_internet_connection()
            try:
                self.after(0, lambda: self.finish_login_connection_check(online))
            except Exception:
                pass

        threading.Thread(target=worker, daemon=True).start()
        self.after(10000, self.check_login_connection_async)

    def finish_login_connection_check(self, online: bool):
        self.login_connection_running = False
        self.update_login_connection_badge(online)

    def change_language(self, value):
        self.selected_language = value
        t = TR[self.selected_language]
        self.title_label.configure(text=t["login_title"])
        self.subtitle_label.configure(text=t["login_subtitle"])
        self.update_fake_placeholder()
        self.login_button.configure(text=t["login_button"])
        self.status_label.configure(text="")

    def update_fake_placeholder(self):
        if self.key_entry.get().strip():
            self.fake_placeholder.place_forget()
        else:
            self.fake_placeholder.place(relx=0.5, rely=0.5, anchor="center")

    def format_key_live(self, event=None):
        current = self.key_entry.get()
        raw = re.sub(r"[^A-Za-z0-9]", "", current).upper()[:12]
        groups = [raw[i:i + 4] for i in range(0, len(raw), 4)]
        formatted = "-".join(groups)

        if formatted != current:
            self.key_entry.delete(0, "end")
            self.key_entry.insert(0, formatted)
            self.key_entry.icursor("end")

        self.update_fake_placeholder()

    def try_login(self):
        key = self.key_entry.get().strip()

        self.login_button.configure(state="disabled", text="Checking...")
        self.status_label.configure(text="Checking license...", text_color="#ffaa33")
        self.update()

        valid, message = is_valid_key(key)

        self.login_button.configure(state="normal", text=TR[self.selected_language]["login_button"])

        if valid:
            self.authenticated = True
            self.selected_language = self.language_var.get()
            self.status_label.configure(text=TR[self.selected_language]["login_success"], text_color=GREEN)
            self.after(250, self.safe_close)
        else:
            self.status_label.configure(text=message or TR[self.selected_language]["login_error"], text_color=RED)
            self.key_entry.focus_set()

    def safe_close(self):
        self.login_connection_active = False
        try:
            self.quit()
        except Exception:
            pass
        try:
            self.destroy()
        except Exception:
            pass



