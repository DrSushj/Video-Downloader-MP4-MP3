    def update_connection_badge(self, online: bool | None):
        self.internet_online = online

        if online is True:
            self.connection_badge.configure(text="● Online", text_color=GREEN)
        elif online is False:
            self.connection_badge.configure(text="● Offline", text_color=RED)
        else:
            self.connection_badge.configure(text="● Checking...", text_color="#ffaa33")

    def start_connection_monitor(self):
        self.update_connection_badge(None)
        self.check_connection_async()

    def check_connection_async(self):
        if self.internet_check_running:
            self.after(10000, self.check_connection_async)
            return

        self.internet_check_running = True

        def worker():
            online = has_internet_connection()
            self.q.put(("connection", online))

        threading.Thread(target=worker, daemon=True).start()
        self.after(10000, self.check_connection_async)

    def current_tooltip_text(self, key: str) -> str:
        return TR[self.lang].get(key, "")

    def create_info_icon(self, parent, column, tooltip_key):
        icon = ctk.CTkLabel(
            parent,
            text="ℹ",
            width=22,
            text_color="#7ea6ff",
            fg_color="transparent",
            font=ctk.CTkFont(size=16, weight="bold"),
            cursor="hand2",
        )
        icon.grid(row=0, column=column, padx=(6, 18), sticky="w")
        HoverInfo(icon, lambda: self.current_tooltip_text(tooltip_key))
        return icon


    def show_confirm_toast(self, title, message, yes_callback, no_callback=None):
        self.toast_notifications = [t for t in self.toast_notifications if t.winfo_exists() and not getattr(t, "hiding", False)]

        while len(self.toast_notifications) >= self.toast_max:
            old = self.toast_notifications.pop(0)
            try:
                old.on_close = None
                old.place_forget()
                old.destroy()
            except Exception:
                pass

        toast = InAppToast(
            self.main,
            title=title,
            message=message,
            kind="info",
            duration=15000,
            on_close=self.remove_toast,
            actions=[
                {"text": tr(self.lang, "yes"), "style": "primary", "command": yes_callback},
                {"text": tr(self.lang, "no"), "style": "secondary", "command": no_callback},
            ],
        )

        self.toast_notifications.append(toast)
        self.position_toasts(animated=False)
        toast.show()


    def init_toast_system(self):
        self.bind("<Configure>", self.on_window_configure)

    def on_window_configure(self, _event=None):
        self.after(10, self.position_toasts)

    def show_toast(self, title, message, kind="info", duration=3200):
        message = str(message).strip()
        if not message:
            return

        self.toast_notifications = [t for t in self.toast_notifications if t.winfo_exists() and not getattr(t, "hiding", False)]

        # Hard limit: never more than 2 toast widgets.
        while len(self.toast_notifications) >= self.toast_max:
            old = self.toast_notifications.pop(0)
            try:
                old.on_close = None
                old.place_forget()
                old.destroy()
            except Exception:
                pass

        toast = InAppToast(
            self.main,
            title=title,
            message=message,
            kind=kind,
            duration=duration,
            on_close=self.remove_toast,
        )
        self.toast_notifications.append(toast)
        self.position_toasts(animated=False)
        toast.show()

    def remove_toast(self, toast):
        if toast in self.toast_notifications:
            self.toast_notifications.remove(toast)
        self.position_toasts(animated=True)

    def position_toasts(self, animated=False):
        if not hasattr(self, "main") or not self.toast_notifications:
            return

        try:
            self.main.update_idletasks()
            width = self.main.winfo_width()
            height = self.main.winfo_height()
        except Exception:
            return

        margin_right = 18
        margin_bottom = 18
        gap = 12

        self.toast_notifications = [t for t in self.toast_notifications if t.winfo_exists() and not getattr(t, "hiding", False)]
        if len(self.toast_notifications) > self.toast_max:
            for old in self.toast_notifications[:-self.toast_max]:
                try:
                    old.on_close = None
                    old.destroy()
                except Exception:
                    pass
            self.toast_notifications = self.toast_notifications[-self.toast_max:]

        for index, toast in enumerate(reversed(self.toast_notifications)):
            x = width - toast.toast_width - margin_right
            y = height - margin_bottom - toast.toast_height - index * (toast.toast_height + gap)
            x = max(10, x)
            y = max(10, y)
            toast.set_target(x, y, animated=animated)

    def add_menu(self, parent, label, variable, values, column):
        lbl = ctk.CTkLabel(parent, text=label, text_color="#bdbdc8")
        lbl.grid(row=0, column=column, sticky="w", pady=(0, 6), padx=(0 if column == 0 else 14, 0))

        menu = ctk.CTkOptionMenu(
            parent,
            values=values,
            variable=variable,
            height=42,
            corner_radius=14,
            fg_color=INPUT,
            button_color="#272735",
            button_hover_color="#343446",
        )
        menu.grid(row=1, column=column, sticky="ew", padx=(0 if column == 0 else 14, 0))
        return lbl, menu

